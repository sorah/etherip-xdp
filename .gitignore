### https://raw.github.com/github/gitignore/master/Rust.gitignore

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Scratch / integration-test cache (kernels, initramfs, sockets, logs).
/tmp/

# These are backup files generated by rustfmt
**/*.rs.bk

# cargo-fuzz generated state (build output, discovered corpus, crash artifacts,
# coverage). The targets under test/fuzzing/ are tracked; these are not.
/test/fuzzing/target/
/test/fuzzing/corpus/
/test/fuzzing/artifacts/
/test/fuzzing/coverage/
